# Toggle the in-memory mock layer. Set to "false" to hit the real FastAPI backend.
# For staging/production deploy, this MUST be false.
NEXT_PUBLIC_USE_MOCK=false
# Base URL of the Karzar FastAPI backend (used when USE_MOCK=false).
# Must include the /api/v1 prefix.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
# Optional absolute origin for product images (PUBLIC_ASSET_BASE). Falls back to API host.
# Example: https://api.karzartools.com
# NEXT_PUBLIC_ASSET_BASE_URL=https://api.karzartools.com
# Simulated network latency (ms) for the mock layer.
NEXT_PUBLIC_MOCK_LATENCY_MS=500

# Analytics — set ONE of these (not both) to avoid double-counting the same GA4 property:
# A) First-party gtag:
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-7LLQJ74Y4F
# B) Google Tag Manager (configure GA4 inside the container, then publish):
# NEXT_PUBLIC_GTM_ID=GTM-P3DR2RSD
# NEXT_PUBLIC_* is inlined at build time — set before `next build` / redeploy.
