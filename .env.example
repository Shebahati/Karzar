# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
# Docker compose runs in host network mode
POSTGRES_SERVER=127.0.0.1
POSTGRES_PORT=5435
POSTGRES_DB=karzar_db

# Redis Configuration (optional — leave REDIS_HOST empty to disable)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Application Settings
PROJECT_NAME=Industrial Lathe Tools API
VERSION=1.0.0
DEBUG=False
ENABLE_API_DOCS=False

# Security (must be at least 32 characters)
SECRET_KEY=replace-with-a-random-secret-key-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
ALLOW_PUBLIC_REGISTER=False
OTP_DEV_ECHO=False
OTP_MESSAGE_TEMPLATE=کد ورود شما به کارزار: {code}

# SMS provider
# SMS_PROVIDER can be: console | kavenegar
SMS_PROVIDER=console
SMS_TIMEOUT_SECONDS=10
# Required only when SMS_PROVIDER=kavenegar
SMS_KAVENEGAR_API_KEY=
SMS_KAVENEGAR_SENDER=
# Optional: use Kavenegar verify template instead of plain sender/message
SMS_KAVENEGAR_OTP_TEMPLATE=

# Payment provider
# PAYMENT_PROVIDER can be: mock | zarinpal
PAYMENT_PROVIDER=mock
# Gateway callback URL (storefront page OR backend /api/v1/payments/callback)
PAYMENT_CALLBACK_URL=http://localhost:3000/checkout/payment/callback
PAYMENT_SUCCESS_REDIRECT_URL=http://localhost:3000/checkout/success
PAYMENT_FAILURE_REDIRECT_URL=http://localhost:3000/checkout/payment/failed
PAYMENT_TIMEOUT_SECONDS=12
# Required only when PAYMENT_PROVIDER=zarinpal
ZARINPAL_MERCHANT_ID=
# Optional override endpoints (keep defaults unless needed)
ZARINPAL_REQUEST_URL=https://payment.zarinpal.com/pg/v4/payment/request.json
ZARINPAL_VERIFY_URL=https://payment.zarinpal.com/pg/v4/payment/verify.json

# Runtime server mode for docker-entrypoint.sh (uvicorn | gunicorn)
APP_SERVER=uvicorn
# GUNICORN_BIND=0.0.0.0:8000
# GUNICORN_WORKERS=4
# GUNICORN_TIMEOUT=60
# GUNICORN_GRACEFUL_TIMEOUT=30
# GUNICORN_KEEPALIVE=5

# Bootstrap super admin (optional — created on startup if no super admin exists)
INITIAL_SUPER_ADMIN_PHONE=09120000000
INITIAL_SUPER_ADMIN_PASSWORD=change-me-admin-password
INITIAL_SUPER_ADMIN_NAME=Super Admin

# Step-up authentication for destructive admin actions
ADMIN_STEP_UP_PIN=8472916350
STEP_UP_TOKEN_EXPIRE_MINUTES=5
