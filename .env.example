# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
# Docker compose runs in host network mode
POSTGRES_SERVER=127.0.0.1
POSTGRES_PORT=5435
POSTGRES_DB=karzar_db

# Redis Configuration (optional — leave REDIS_HOST empty to disable)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Application Settings
PROJECT_NAME=Industrial Lathe Tools API
VERSION=1.0.0
DEBUG=False

# Security (must be at least 32 characters)
SECRET_KEY=replace-with-a-random-secret-key-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
ALLOW_PUBLIC_REGISTER=False
OTP_DEV_ECHO=False
OTP_MESSAGE_TEMPLATE=کد ورود شما به کارزار: {code}

# SMS provider
# SMS_PROVIDER can be: console | kavenegar
SMS_PROVIDER=console
SMS_TIMEOUT_SECONDS=10
# Required only when SMS_PROVIDER=kavenegar
SMS_KAVENEGAR_API_KEY=
SMS_KAVENEGAR_SENDER=
# Optional: use Kavenegar verify template instead of plain sender/message
SMS_KAVENEGAR_OTP_TEMPLATE=

# Bootstrap super admin (optional — created on startup if no super admin exists)
INITIAL_SUPER_ADMIN_PHONE=09120000000
INITIAL_SUPER_ADMIN_PASSWORD=change-me-admin-password
INITIAL_SUPER_ADMIN_NAME=Super Admin

# Step-up authentication for destructive admin actions
ADMIN_STEP_UP_PIN=change-me-admin-pin
STEP_UP_TOKEN_EXPIRE_MINUTES=5
