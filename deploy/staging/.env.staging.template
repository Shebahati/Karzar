# Copy to Karzar/.env on the VPS (never commit secrets).
# Replace EVERY replace-me / example.com value before first boot.

APP_ENV=staging
DEBUG=False
ENABLE_API_DOCS=False
OTP_DEV_ECHO=False
ENABLE_METRICS=True
ENFORCE_HTTPS=True
LOG_TO_FILE=True
LOG_FILE=/app/logs/app.log
MAX_REQUEST_BODY_BYTES=1048576

# Public API hostname only (comma-separated if needed)
TRUSTED_HOSTS=api.example.com
# Nginx on the same host terminates TLS
TRUSTED_PROXIES=127.0.0.1
PUBLIC_ASSET_BASE=https://api.example.com

POSTGRES_USER=karzar_staging
POSTGRES_PASSWORD=replace-me-strong-db-password
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=karzar_staging

REDIS_HOST=redis
REDIS_PORT=6379

SECRET_KEY=replace-me-with-random-secret-at-least-32-chars
ADMIN_STEP_UP_PIN=replace-me-8plus-digits
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
STEP_UP_TOKEN_EXPIRE_MINUTES=15

CORS_ORIGINS=https://shop.example.com,https://admin.example.com

# Staging: keep mock/console until Zarinpal + Kavenegar are purchased
SMS_PROVIDER=console
PAYMENT_PROVIDER=mock
PAYMENT_CALLBACK_URL=https://shop.example.com/checkout/payment/callback
PAYMENT_SUCCESS_REDIRECT_URL=https://shop.example.com/checkout/success
PAYMENT_FAILURE_REDIRECT_URL=https://shop.example.com/checkout/payment/failed

INITIAL_SUPER_ADMIN_PHONE=09120000000
INITIAL_SUPER_ADMIN_PASSWORD=replace-me-strong-admin-password
INITIAL_SUPER_ADMIN_NAME=Staging Admin

APP_SERVER=gunicorn
GUNICORN_WORKERS=2

ALLOW_PUBLIC_REGISTER=true
PROJECT_NAME=Karzar Staging API
VERSION=1.0.0
ALGORITHM=HS256
