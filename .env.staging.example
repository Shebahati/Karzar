# Staging environment template — copy to .env.staging and fill secrets.

APP_ENV=staging
DEBUG=False
ENABLE_API_DOCS=False
OTP_DEV_ECHO=False
ENABLE_METRICS=True
ENFORCE_HTTPS=True
LOG_TO_FILE=True
LOG_FILE=/app/logs/app.log
MAX_REQUEST_BODY_BYTES=1048576
TRUSTED_HOSTS=api.staging.example.com

# Database (inside compose network)
POSTGRES_USER=karzar_staging
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=karzar_staging

REDIS_HOST=redis
REDIS_PORT=6379

SECRET_KEY=replace-with-a-random-secret-key-at-least-32-chars
ADMIN_STEP_UP_PIN=replace-with-strong-pin
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

CORS_ORIGINS=https://staging-shop.example.com,https://staging-admin.example.com

SMS_PROVIDER=console
PAYMENT_PROVIDER=mock
PAYMENT_CALLBACK_URL=https://staging-shop.example.com/checkout/payment/callback
PAYMENT_SUCCESS_REDIRECT_URL=https://staging-shop.example.com/checkout/success
PAYMENT_FAILURE_REDIRECT_URL=https://staging-shop.example.com/checkout/payment/failed

INITIAL_SUPER_ADMIN_PHONE=
INITIAL_SUPER_ADMIN_PASSWORD=
INITIAL_SUPER_ADMIN_NAME=Staging Admin

APP_SERVER=gunicorn
GUNICORN_WORKERS=2
